// 049: Comprehensive test — struct, enum, const, if/else, operators
const MAX : i32 = 100

struct Point {
    x: i32,
    y: i32,
}

enum Status {
    Active,
    Inactive,
}

func is_positive(n: i32) -> bool {
    ret n > 0
}

func abs(n: i32) -> i32 {
    if n >= 0 {
        ret n
    }
    ret -n
}

pub func main() -> i32 {
    mut v : i32 = -5
    v = abs(v)
    if is_positive(v) {
        v = v + 1
    } else {
        v = 0
    }
    ret v
}
