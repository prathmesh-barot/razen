// 055: Enum match with printed output (use if-else for guaranteed return)
ext func puts(s: str) -> i32

enum Color {
    Red,
    Green,
    Blue,
}

func name(c: Color) -> i32 {
    if c == Color.Red {
        ret 1
    }
    if c == Color.Green {
        ret 2
    }
    if c == Color.Blue {
        ret 3
    }
    ret 0
}

pub func main() -> i32 {
    puts("match test")
    ret name(Color.Green)
}
