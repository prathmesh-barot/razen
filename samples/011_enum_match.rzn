// 011: Enum with match
enum Color {
    Red,
    Green,
    Blue,
}

func code(c: Color) -> i32 {
    mut r : i32 = 0
    match c {
        Color.Red   => r = 1,
        Color.Green => r = 2,
        Color.Blue  => r = 3,
        else => r = 0,
    }
    ret r
}

pub func main() -> i32 {
    ret code(Color.Blue)
}
