// loops

// razen has universal loops
loop can do work of while, for and loop works.

use std.fmt

// loop
loop {
    fmt.println("Hello", .{})
    break
}

// loop as for loop

items := [1,2,3,4,5]

loop items |i| {
    fmt.println("{}", .{i})
}

// loop as while loop

num := 0
loop num <= 10 {
    fmt.println("{}", .{num})
    num += 1
}
